# Base URL of the MediPOS API (the medipos-server Express process).
# The client appends /api/v1 itself. This is NOT the Vite dev server (:5173) —
# it's the separate backend, which runs on :3000 per medipos-server/.env.
VITE_API_URL=http://localhost:3000

# Optional: shop name printed on the thermal receipt header. Interim until
# per-tenant white-label branding (Phase 3) supplies it from the server.
# VITE_SHOP_NAME=Your Pharmacy Name
